{
  "name": "Idea to Creative Pipeline",
  "nodes": [
    {
      "parameters": {},
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [-1200, 0],
      "id": "2c3d4e5f-0001-0001-0001-000000000001",
      "name": "Manual Trigger"
    },
    {
      "parameters": {
        "jsCode": "// ─── ADD YOUR IDEAS AND SETTINGS HERE ───────────────────────────────────────\nconst OPENROUTER_API_KEY = 'YOUR_OPENROUTER_API_KEY_HERE';\nconst WAVESPEED_API_KEY  = 'YOUR_WAVESPEED_API_KEY_HERE';\nconst LLM_MODEL          = 'anthropic/claude-3-5-haiku';\nconst IMAGE_MODEL        = 'bytedance/seedream-v4';\nconst IMAGE_SIZE         = '1024*1024';\nconst GDRIVE_FOLDER_ID   = '1Czg44HSJiJxPB9tJxDS6-6NOCJXqjiuS';\n\nconst ideas = [\n  'A cozy autumn coffee shop scene with warm lighting',\n  'Futuristic smart city with flying cars and holographic billboards',\n  'Serene beachside yoga session at golden hour'\n];\n// ─────────────────────────────────────────────────────────────────────────────\n\n// Returns one item per idea — each flows through the full pipeline independently\nreturn ideas.map(idea => ({\n  json: { idea, OPENROUTER_API_KEY, WAVESPEED_API_KEY, LLM_MODEL, IMAGE_MODEL, IMAGE_SIZE, GDRIVE_FOLDER_ID }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1000, 0],
      "id": "2c3d4e5f-0002-0002-0002-000000000002",
      "name": "Define Ideas"
    },
    {
      "parameters": {
        "jsCode": "const idea = $json.idea;\nconst model = $json.LLM_MODEL;\n\nconst systemPrompt = `You are a creative content strategist for social media.\nGiven an idea, produce a complete content package.\n\nRespond ONLY with valid JSON — no markdown fences, no extra text:\n{\n  \"hook\": \"A compelling 1–2 sentence opening that stops the scroll\",\n  \"image_prompt\": \"A richly detailed image generation prompt covering subject, style, lighting, composition, colour palette, and mood\",\n  \"caption\": \"An engaging social media caption ending with 3–5 relevant hashtags\"\n}`;\n\nconst requestBody = {\n  model: model,\n  messages: [\n    { role: 'system', content: systemPrompt },\n    { role: 'user',   content: `Create a content package for this idea: ${idea}` }\n  ],\n  response_format: { type: 'json_object' },\n  temperature: 0.8,\n  max_tokens: 800\n};\n\nreturn [{\n  json: {\n    ...$json,\n    openrouter_body: JSON.stringify(requestBody)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-800, 0],
      "id": "2c3d4e5f-0003-0003-0003-000000000003",
      "name": "Build LLM Request"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.OPENROUTER_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ $json.openrouter_body }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [-600, 0],
      "id": "2c3d4e5f-0004-0004-0004-000000000004",
      "name": "Generate Content"
    },
    {
      "parameters": {
        "jsCode": "const rawContent = $input.item.json.choices[0].message.content;\nlet parsed;\n\ntry {\n  parsed = JSON.parse(rawContent);\n} catch (e) {\n  // Strip markdown code fences if the model wrapped its output\n  const match = rawContent.match(/```(?:json)?\\s*([\\s\\S]*?)\\s*```/);\n  if (match) {\n    parsed = JSON.parse(match[1]);\n  } else {\n    throw new Error('LLM response is not valid JSON: ' + rawContent.slice(0, 300));\n  }\n}\n\nconst cfg = $('Define Ideas').item.json;\n\nreturn [{\n  json: {\n    idea:             cfg.idea,\n    hook:             parsed.hook,\n    image_prompt:     parsed.image_prompt,\n    caption:          parsed.caption,\n    WAVESPEED_API_KEY: cfg.WAVESPEED_API_KEY,\n    IMAGE_MODEL:      cfg.IMAGE_MODEL,\n    IMAGE_SIZE:       cfg.IMAGE_SIZE,\n    LLM_MODEL:        cfg.LLM_MODEL,\n    GDRIVE_FOLDER_ID: cfg.GDRIVE_FOLDER_ID\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-400, 0],
      "id": "2c3d4e5f-0005-0005-0005-000000000005",
      "name": "Parse LLM Response"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.wavespeed.ai/api/v3/{{ $json.IMAGE_MODEL }}",
        "sendHeaders": true,
