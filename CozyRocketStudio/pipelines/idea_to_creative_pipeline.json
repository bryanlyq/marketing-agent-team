      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [1260, -180],
      "id": "2c3d4e5f-0013-0013-0013-000000000013",
      "name": "Upload Image",
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "KM9OwALPjFdCsIhN",
          "name": "Google Drive account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const fileMeta = $('Generate File Name').item.json;\nconst driveResponse = $input.item.json;\n\nconst metadata = {\n  request_id:            fileMeta.request_id,\n  idea:                  fileMeta.idea,\n  hook:                  fileMeta.hook,\n  image_prompt:          fileMeta.image_prompt,\n  caption:               fileMeta.caption,\n  image_model:           fileMeta.image_model,\n  llm_model:             fileMeta.llm_model,\n  image_size:            fileMeta.image_size,\n  submitted_at:          fileMeta.submitted_at,\n  completed_at:          fileMeta.completed_at,\n  image_file_name:       fileMeta.image_file_name,\n  google_drive_file_id:  driveResponse.id || '',\n  google_drive_web_link: driveResponse.webViewLink || '',\n  pipeline_version:      '1.0'\n};\n\nconst metadataString = JSON.stringify(metadata, null, 2);\n\nconst binaryData = await this.helpers.prepareBinaryData(\n  Buffer.from(metadataString, 'utf-8'),\n  fileMeta.metadata_file_name,\n  'application/json'\n);\n\nreturn [{\n  json: {\n    ...fileMeta,\n    metadata_json:        metadataString,\n    google_drive_file_id: driveResponse.id || '',\n    google_drive_web_link: driveResponse.webViewLink || ''\n  },\n  binary: { data: binaryData }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1480, -180],
      "id": "2c3d4e5f-0014-0014-0014-000000000014",
