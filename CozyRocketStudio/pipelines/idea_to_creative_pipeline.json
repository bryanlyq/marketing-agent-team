      "position": [600, 0],
      "id": "2c3d4e5f-0010-0010-0010-000000000010",
      "name": "Job Complete?"
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Store Job Context').item.json;\nconst imageUrl = $input.item.json.data.outputs[0];\nconst completedAt = new Date().toISOString();\n\nconst timestamp = completedAt\n  .replace('T', '_')\n  .replace(/:/g, '-')\n  .slice(0, 19);\n\nconst sanitizedIdea = ctx.idea\n  .toLowerCase()\n  .replace(/[^a-z0-9\\s]/g, '')\n  .trim()\n  .replace(/\\s+/g, '_')\n  .replace(/_{2,}/g, '_')\n  .slice(0, 40)\n  .replace(/_+$/, '');\n\nconst modelSlug = ctx.image_model.split('/').pop();\nconst baseName = `${sanitizedIdea}_${timestamp}_${modelSlug}`;\n\nreturn [{\n  json: {\n    base_name:             baseName,\n    image_file_name:       `${baseName}.png`,\n    metadata_file_name:    `${baseName}_metadata.json`,\n    idea:                  ctx.idea,\n    hook:                  ctx.hook,\n    image_prompt:          ctx.image_prompt,\n    caption:               ctx.caption,\n    image_model:           ctx.image_model,\n    llm_model:             ctx.llm_model,\n    image_size:            ctx.image_size,\n    request_id:            ctx.request_id,\n    submitted_at:          ctx.submitted_at,\n    completed_at:          completedAt,\n    image_url:             imageUrl,\n    gdrive_folder_id:      ctx.gdrive_folder_id\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [820, -180],
      "id": "2c3d4e5f-0011-0011-0011-000000000011",
