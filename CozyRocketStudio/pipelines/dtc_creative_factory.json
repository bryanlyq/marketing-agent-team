    "Update Status: Generating": {
      "main": [
        [
          {
            "node": "Build Prompt Array",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build Prompt Array": {
      "main": [
        [
          {
            "node": "Loop Prompts",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Loop Prompts": {
      "main": [
        [
          {
            "node": "Build WaveSpeed Request",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Update Status: Done",
            "type": "main",
            "index": 0
          }
        ]
      ]
