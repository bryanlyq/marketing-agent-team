              "name": "gdrive_folder_id",
              "value": "={{ $('Define Prompts').item.json.GDRIVE_FOLDER_ID }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-400, 0],
      "id": "1a2b3c4d-0005-0005-0005-000000000005",
      "name": "Store Job Context"
    },
    {
      "parameters": {
        "amount": 15
      },
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [-200, 0],
      "id": "1a2b3c4d-0006-0006-0006-000000000006",
      "name": "Initial Wait",
      "webhookId": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
    },
    {
      "parameters": {
        "url": "={{ $('Store Job Context').item.json.poll_url }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('Define Prompts').item.json.WAVESPEED_API_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [0, 0],
      "id": "1a2b3c4d-0007-0007-0007-000000000007",
      "name": "Poll Job Status",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "cond-001",
              "leftValue": "={{ $json.data.status }}",
              "rightValue": "completed",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [200, 0],
      "id": "1a2b3c4d-0008-0008-0008-000000000008",
      "name": "Job Complete?"
    },
    {
      "parameters": {
        "jsCode": "// Pull context saved before polling loop started\nconst ctx = $('Store Job Context').item.json;\nconst pollResponse = $input.item.json;\n\nconst imageUrl = pollResponse.data.outputs[0];\nconst completedAt = new Date().toISOString();\n\n// Build timestamp: 2025-01-15_14-30-00\nconst timestamp = completedAt\n  .replace('T', '_')\n  .replace(/:/g, '-')\n  .slice(0, 19);\n\n// Sanitize prompt for use in filename: max 40 chars, snake_case\nconst sanitizedPrompt = ctx.prompt\n  .toLowerCase()\n  .replace(/[^a-z0-9\\s]/g, '')\n  .trim()\n  .replace(/\\s+/g, '_')\n  .replace(/_{2,}/g, '_')\n  .slice(0, 40)\n  .replace(/_+$/, '');\n\n// e.g. seedream-v4\nconst modelSlug = ctx.model.split('/').pop();\n\n// Final file base name\nconst baseName = `${sanitizedPrompt}_${timestamp}_${modelSlug}`;\n\nreturn [{\n  json: {\n    base_name: baseName,\n    image_file_name: `${baseName}.png`,\n    metadata_file_name: `${baseName}_metadata.json`,\n    prompt: ctx.prompt,\n    model: ctx.model,\n    model_slug: modelSlug,\n    image_size: ctx.image_size,\n    request_id: ctx.request_id,\n    submitted_at: ctx.submitted_at,\n    completed_at: completedAt,\n    image_url: imageUrl,\n    gdrive_folder_id: ctx.gdrive_folder_id\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, -180],
      "id": "1a2b3c4d-0009-0009-0009-000000000009",
      "name": "Generate File Name"
    },
    {
      "parameters": {
        "url": "={{ $json.image_url }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file",
              "outputPropertyName": "data"
            }
          }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [640, -180],
      "id": "1a2b3c4d-0010-0010-0010-000000000010",
      "name": "Download Image"
    },
    {
      "parameters": {
        "operation": "upload",
        "name": "={{ $('Generate File Name').item.json.image_file_name }}",
        "driveId": {
          "__rl": true,
          "mode": "list",
          "value": "My Drive"
        },
        "folderId": {
          "__rl": true,
          "value": "={{ $('Generate File Name').item.json.gdrive_folder_id }}",
          "mode": "id"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [860, -180],
      "id": "1a2b3c4d-0011-0011-0011-000000000011",
      "name": "Upload Image",
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "KM9OwALPjFdCsIhN",
          "name": "Google Drive account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Build the metadata record and convert to a binary JSON file for upload\nconst fileMeta = $('Generate File Name').item.json;\nconst driveResponse = $input.item.json;\n\nconst metadata = {\n  request_id: fileMeta.request_id,\n  prompt: fileMeta.prompt,\n  model: fileMeta.model,\n  image_size: fileMeta.image_size,\n  submitted_at: fileMeta.submitted_at,\n  completed_at: fileMeta.completed_at,\n  image_file_name: fileMeta.image_file_name,\n  google_drive_file_id: driveResponse.id || '',\n  google_drive_web_link: driveResponse.webViewLink || '',\n  pipeline_version: '2.0'\n};\n\nconst metadataString = JSON.stringify(metadata, null, 2);\n\nconst binaryData = await this.helpers.prepareBinaryData(\n  Buffer.from(metadataString, 'utf-8'),\n  fileMeta.metadata_file_name,\n  'application/json'\n);\n\nreturn [{\n  json: {\n    ...fileMeta,\n    metadata_json: metadataString,\n    google_drive_file_id: driveResponse.id || '',\n    google_drive_web_link: driveResponse.webViewLink || ''\n  },\n  binary: {\n    data: binaryData\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1080, -180],
      "id": "1a2b3c4d-0012-0012-0012-000000000012",
      "name": "Prepare Metadata"
    },
    {
      "parameters": {
        "operation": "upload",
        "name": "={{ $json.metadata_file_name }}",
        "driveId": {
          "__rl": true,
          "mode": "list",
          "value": "My Drive"
        },
        "folderId": {
          "__rl": true,
          "value": "={{ $json.gdrive_folder_id }}",
          "mode": "id"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [1300, -180],
      "id": "1a2b3c4d-0013-0013-0013-000000000013",
      "name": "Upload Metadata",
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "KM9OwALPjFdCsIhN",
          "name": "Google Drive account"
        }
      }
    },
