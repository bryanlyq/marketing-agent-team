{
  "name": "Wavespeed Batch Image Pipeline v2",
  "nodes": [
    {
      "parameters": {},
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [-1200, 0],
      "id": "1a2b3c4d-0001-0001-0001-000000000001",
      "name": "Manual Trigger"
    },
    {
      "parameters": {
        "jsCode": "// ─── CONFIGURE YOUR PROMPTS AND SETTINGS HERE ───────────────────────────────\nconst WAVESPEED_API_KEY = 'YOUR_WAVESPEED_API_KEY_HERE';\nconst MODEL             = 'bytedance/seedream-v4';\nconst IMAGE_SIZE        = '1024*1024';\nconst GDRIVE_FOLDER_ID  = '1Czg44HSJiJxPB9tJxDS6-6NOCJXqjiuS';\n\nconst prompts = [\n  'American retro style: a woman wearing a polka-dot dress with sunglasses adorning her head',\n  'Cyberpunk cityscape at night with neon lights reflecting on rain-soaked streets',\n  'Minimalist Japanese garden with cherry blossoms and a stone pathway'\n];\n// ─────────────────────────────────────────────────────────────────────────────\n\n// Returns one item per prompt — each flows through the pipeline independently\nreturn prompts.map(prompt => ({\n  json: { prompt, WAVESPEED_API_KEY, MODEL, IMAGE_SIZE, GDRIVE_FOLDER_ID }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1000, 0],
      "id": "1a2b3c4d-0002-0002-0002-000000000002",
      "name": "Define Prompts"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.wavespeed.ai/api/v3/{{ $json.MODEL }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.WAVESPEED_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "enable_base64_output",
              "value": "false"
            },
            {
              "name": "enable_sync_mode",
              "value": "false"
            },
            {
              "name": "prompt",
              "value": "={{ $json.prompts }}"
            },
            {
              "name": "size",
              "value": "={{ $json.IMAGE_SIZE }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [-600, 0],
      "id": "1a2b3c4d-0004-0004-0004-000000000004",
      "name": "Submit Image Job"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "ctx-001",
              "name": "request_id",
              "value": "={{ $json.data.id }}",
              "type": "string"
            },
            {
              "id": "ctx-002",
              "name": "poll_url",
              "value": "={{ $json.data.urls.get }}",
              "type": "string"
            },
            {
              "id": "ctx-003",
              "name": "prompt",
              "value": "={{ $('Define Prompts').item.json.prompt }}",
              "type": "string"
            },
            {
              "id": "ctx-004",
